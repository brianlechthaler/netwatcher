# Gateway API key (required in production; set on gateway and capture agents)
GATEWAY_API_KEY=
# Reject ingest when GATEWAY_API_KEY is unset (recommended for production)
GATEWAY_REQUIRE_API_KEY=false
GATEWAY_MAX_BODY_BYTES=10485760
GATEWAY_MAX_EVENTS_PER_BATCH=500
GATEWAY_RATE_LIMIT_PER_MINUTE=600

# Capture agent settings (remote or local)
# Use "auto" to pick the default-route interface, or set an explicit name (e.g. enp4s0).
CAPTURE_INTERFACE=auto
GATEWAY_URL=http://127.0.0.1:8080
AGENT_ID=capture-agent-1

# MCP server security (optional)
MCP_RATE_LIMIT_PER_MINUTE=120
MCP_MAX_REQUEST_BYTES=65536
MCP_MAX_QUERY_LENGTH=1024
MCP_MAX_RESULTS_LIMIT=100
MCP_MAX_HOURS=168
MCP_MAX_RESPONSE_BYTES=524288
# MCP_ENABLED_TOOLS=search_events,threat_summary,analyze_ip,list_sources
# MCP_ALLOWED_SOURCES=zeek,p0f,fatt,enriched
